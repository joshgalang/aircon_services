# App
JWT_SECRET="use-a-long-random-string-in-production"
PORT=4000

# Browser origins allowed to call this API (comma-separated). Required in production.
# Example: https://your-app.vercel.app,https://www.yourdomain.com
# CORS_ORIGIN=

# Database (.env.local) — copy strings from Supabase Dashboard → Connect (do not guess hosts).
#
# Prisma runtime (pooled / transaction mode, port 6543):
#   postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true&sslmode=require
#
# Prisma directUrl (migrations), direct DB port 5432:
#   postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
#
# Persistent Node API (optional): you can use Session pooler (IPv4) for BOTH url and directUrl — use the
# "Session mode" URI from the dashboard for Express if direct :5432 is unreachable.
