# Vercel: import this repo, set Root Directory to `frontend`, Framework Preset Next.js.
# Then copy these into Project → Settings → Environment Variables (Production + Preview).
# No trailing slash on URLs.

# Deployed Express API (HTTPS in production), no trailing slash, must include /api prefix
NEXT_PUBLIC_API_URL=https://aircon-services-backend.vercel.app/api

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-or-publishable-key

# Public inquiry form default branch (matches seeded Branch.id)
NEXT_PUBLIC_DEFAULT_BRANCH_ID=1

# Optional white-label
# NEXT_PUBLIC_WHITELABEL_LOGO_URL=https://...
# NEXT_PUBLIC_WHITELABEL_NAME=Your Company
